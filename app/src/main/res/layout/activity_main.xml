<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondoActivity"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/tituloHome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ahorcado"
        android:textColor="@color/black"
        android:textSize="64sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.496"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.128" />

    <ImageView
        android:id="@+id/settingsImd"
        android:layout_width="107dp"
        android:layout_height="62dp"
        android:layout_marginEnd="36dp"
        android:src="@drawable/home_gotas"
        app:layout_constraintBottom_toBottomOf="@id/tituloHome"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.707" />

    <android.widget.Button
        android:layout_width="43dp"
        android:layout_height="43dp"
        android:background="@drawable/img_settings"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/tituloHome"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tituloHome"
        app:layout_constraintVertical_bias="1"/>

    <ImageView
        android:id="@+id/homeImd_ahorcado"
        android:layout_width="339dp"
        android:layout_height="331dp"
        android:src="@drawable/img_ahorcado"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tituloHome"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.2"
        />

    <LinearLayout
        android:id="@+id/btnPlay"
        android:layout_width="249dp"
        android:layout_height="61dp"
        android:background="@drawable/btn_play"
        android:backgroundTint="#E5E3E3"
        android:onClick="goMenu"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/homeImd_ahorcado"
        app:layout_constraintVertical_bias="0.45">

        <ImageView
            android:layout_width="38dp"
            android:layout_height="37dp"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="60dp"
            android:src="@drawable/img_play_icon" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="10dp"
            android:text="Play"
            android:textColor="@color/black"
            android:textSize="36dp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tituloHome"
        app:layout_constraintBottom_toBottomOf="parent"
        android:orientation="vertical"
        app:layout_constraintVertical_bias="1">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:scaleType="fitXY"
            android:src="@drawable/img3_inicio"/>
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:scaleType="fitXY"
            android:src="@drawable/img2_inicio"/>
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="200dp"
           android:scaleType="fitXY"
            android:src="@drawable/img1_inicio"/>

    </LinearLayout>




</androidx.constraintlayout.widget.ConstraintLayout>